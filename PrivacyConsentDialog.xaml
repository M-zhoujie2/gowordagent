<Window x:Class="GOWordAgentAddIn.PrivacyConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="隐私与安全提示" 
        SizeToContent="WidthAndHeight"
        Width="480"
        MaxHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">
    <Border Padding="20">
        <StackPanel MaxWidth="440">
            <!-- 标题 -->
            <TextBlock Text="&#x26A0; 隐私与安全提示" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="#D32F2F"
                       Margin="0,0,0,10"/>
            
            <!-- 说明文本 -->
            <TextBlock Text="在使用 AI 校对功能前，请您了解以下重要信息：" 
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            
            <!-- 隐私警告内容 -->
            <Border Background="#FFF3E0" 
                    BorderBrush="#FF9800" 
                    BorderThickness="1" 
                    CornerRadius="4"
                    Padding="10"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="1. 文档内容将被发送到 AI 服务商" 
                               FontWeight="SemiBold" Margin="0,0,0,2" FontSize="12"/>
                    <TextBlock Text="校对过程中，文档内容会发送到您配置的 AI 服务商进行分析。" 
                               TextWrapping="Wrap" FontSize="11" Margin="0,0,0,6"/>
                    
                    <TextBlock Text="2. 敏感信息风险" 
                               FontWeight="SemiBold" Margin="0,0,0,2" FontSize="12"/>
                    <TextBlock Text="如果文档包含身份证号、银行账号、密码等敏感信息，这些内容也会被发送。" 
                               TextWrapping="Wrap" FontSize="11" Margin="0,0,0,6"/>
                    
                    <TextBlock Text="3. 数据留存" 
                               FontWeight="SemiBold" Margin="0,0,0,2" FontSize="12"/>
                    <TextBlock Text="第三方 AI 服务商可能会根据各自的服务条款留存您的请求数据。" 
                               TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>
            
            <!-- 建议 -->
            <TextBlock Text="建议措施：" FontWeight="SemiBold" Margin="0,0,0,2" FontSize="12"/>
            <TextBlock Text="&#x2022; 不要校对包含高度敏感信息的文档&#x0A;&#x2022; 使用本地 AI 服务（如 Ollama）可避免数据发送到云端&#x0A;&#x2022; 使用前先了解您选择的 AI 服务商的隐私政策" 
                       TextWrapping="Wrap" FontSize="11"
                       Margin="0,0,0,12"/>
            
            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" 
                        Content="取消" 
                        Width="75" 
                        Height="28"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnAgree" 
                        Content="我已了解并同意" 
                        Width="110" 
                        Height="28"
                        Background="#0078D4"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="BtnAgree_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
