<UserControl x:Class="GOWordAgentAddIn.GOWordAgentPaneWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:GOWordAgentAddIn.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="430"
             Background="#FFFAFA">
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="PrimaryLightColor" Color="#E8F2FC"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFFAFA"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#222222"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#999999"/>
        <SolidColorBrush x:Key="UserBubbleColor" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="AIBubbleColor" Color="#F5F5F5"/>
        
        <!-- Styles -->
        <Style x:Key="HeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
        </Style>
        
        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource InputStyle}"/>
        <Style x:Key="TextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputStyle}"/>
        
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <!-- 按钮圆角附加属性 -->
        <CornerRadius x:Key="DefaultButtonCornerRadius">6</CornerRadius>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Tag" Value="{StaticResource DefaultButtonCornerRadius}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="{TemplateBinding Tag}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Message Bubble Colors -->
        <SolidColorBrush x:Key="SystemBubbleColor" Color="#E8F2FC"/>
        <SolidColorBrush x:Key="ErrorBubbleColor" Color="#FFEBEE"/>
        <SolidColorBrush x:Key="ErrorTextColor" Color="#C62828"/>
        
        <!-- Complex Message DataTemplate -->
        <DataTemplate x:Key="ComplexMessageTemplate" DataType="{x:Type vm:ComplexMessageViewModel}">
            <Grid HorizontalAlignment="{Binding HorizontalAlignment}" Margin="0,0,0,8">
                <ContentPresenter Content="{Binding Content}"/>
            </Grid>
        </DataTemplate>
        
        <!-- Message Bubble DataTemplate -->
        <DataTemplate x:Key="MessageBubbleTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <Grid HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignmentConverter}}" 
                  Margin="0,0,0,8">
                <Border Background="{Binding MessageType, Converter={StaticResource MessageTypeToBrushConverter}}"
                        CornerRadius="{Binding IsUser, Converter={StaticResource BoolToCornerRadiusConverter}}"
                        Padding="12,10" MaxWidth="350">
                    <StackPanel>
                        <!-- Header: Sender + Time + Copy Button -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryColor}" 
                                       VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="Sender"/>
                                        <Binding Path="Time"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <Button Grid.Column="1" Content="{Binding CopyButtonText}"
                                    FontSize="9" Foreground="{StaticResource TextSecondaryColor}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,0,0,0" Cursor="Hand"
                                    Command="{Binding CopyCommand}"
                                    Visibility="{Binding ShowCopyButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                        <!-- Content -->
                        <TextBlock Text="{Binding Content}" FontSize="13" 
                                   TextWrapping="Wrap" Margin="0,6,0,0">
                            <TextBlock.Foreground>
                                <Binding Path="IsError">
                                    <Binding.Converter>
                                        <vm:BoolToErrorBrushConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
        
        <!-- Converters -->
        <vm:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
        <vm:MessageTypeToBrushConverter x:Key="MessageTypeToBrushConverter"/>
        <vm:BoolToCornerRadiusConverter x:Key="BoolToCornerRadiusConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12,2A2,2 0 0,1 14,4A2,2 0 0,1 12,6A2,2 0 0,1 10,4A2,2 0 0,1 12,2M12,7L15,7L15,11L12,11L12,7M3,13H21V21H3V13M5,15V19H19V15H5Z" 
                          Fill="{StaticResource PrimaryColor}" Width="22" Height="22" Stretch="Uniform"/>
                    <TextBlock Text="AI 智能助手" FontSize="15" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryColor}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblHeaderStatus" Text="状态：就绪" FontSize="11" 
                               Foreground="Green" Margin="10,0,0,0" VerticalAlignment="Center"
                               MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnProofread" Content="纠错（审阅）"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="10,5" FontSize="12" Margin="0,0,8,0">
                        <Button.Tag>
                            <CornerRadius>4</CornerRadius>
                        </Button.Tag>
                    </Button>
                    <Button x:Name="BtnClear" Content="清空" Click="BtnClear_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            Padding="10,5" FontSize="12">
                        <Button.Tag>
                            <CornerRadius>4</CornerRadius>
                        </Button.Tag>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Chat Content -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      Margin="10" Visibility="Visible">
            <ItemsControl x:Name="ChatMessagesControl">
                <ItemsControl.Resources>
                    <DataTemplate DataType="{x:Type vm:ChatMessageViewModel}">
                        <Grid HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignmentConverter}}" 
                              Margin="0,0,0,8">
                            <Border Background="{Binding MessageType, Converter={StaticResource MessageTypeToBrushConverter}}"
                                    CornerRadius="{Binding IsUser, Converter={StaticResource BoolToCornerRadiusConverter}}"
                                    Padding="12,10" MaxWidth="350">
                                <StackPanel>
                                    <!-- Header: Sender + Time + Copy Button -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryColor}" 
                                                   VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="Sender"/>
                                                    <Binding Path="Time"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Button Grid.Column="1" Content="{Binding CopyButtonText}"
                                                FontSize="9" Foreground="{StaticResource TextSecondaryColor}"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="4,0,0,0" Cursor="Hand"
                                                Command="{Binding CopyCommand}"
                                                Visibility="{Binding ShowCopyButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <!-- Content -->
                                    <TextBlock Text="{Binding Content}" FontSize="13" 
                                               TextWrapping="Wrap" Margin="0,6,0,0">
                                        <TextBlock.Foreground>
                                            <Binding Path="IsError">
                                                <Binding.Converter>
                                                    <vm:BoolToErrorBrushConverter/>
                                                </Binding.Converter>
                                            </Binding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ComplexMessageViewModel}">
                        <Grid HorizontalAlignment="{Binding HorizontalAlignment}" Margin="0,0,0,8">
                            <ContentPresenter Content="{Binding Content}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.Resources>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Settings Content -->
        <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      Margin="10" Visibility="Collapsed">
            <StackPanel>
                <!-- Tabs -->
                <Grid Background="White" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TabAIConfig" Grid.Column="0" Content="AI 配置" Click="TabAIConfig_Click"
                            BorderThickness="0,0,0,2" BorderBrush="{StaticResource PrimaryColor}"
                            Background="Transparent" Padding="10" FontSize="13" FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryColor}"/>
                    <Button x:Name="TabProofreadConfig" Grid.Column="1" Content="校验配置" Click="TabProofreadConfig_Click"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent"
                            Background="Transparent" Padding="10" FontSize="13"
                            Foreground="{StaticResource TextSecondaryColor}"/>
                </Grid>
                
                <!-- AI Config Panel -->
                <StackPanel x:Name="PanelAIConfig">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="API 服务商" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbAIProvider" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,4"/>
                            <TextBlock Text="用于调用大模型的认证密钥" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryColor}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtApiKey" Style="{StaticResource PasswordBoxStyle}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="模型" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtModel" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="API 地址" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,4"/>
                            <TextBlock Text="默认使用官方地址，自定义时填写" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryColor}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtApiUrl" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,16"/>
                            
                            <Button x:Name="BtnConnect" Content="保存并连接" 
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Status -->
                    <TextBlock x:Name="LblAIConfigStatus" Text="状态：未连接" 
                               Foreground="{StaticResource TextSecondaryColor}" FontSize="12" Margin="4,0,0,10"/>

                </StackPanel>
                
                <!-- Proofread Config Panel -->
                <StackPanel x:Name="PanelProofreadConfig" Visibility="Collapsed">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="校验模式" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbProofreadMode" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,12">
                                <ComboBoxItem Content="精准校验" IsSelected="True"/>
                                <ComboBoxItem Content="全文校验"/>
                            </ComboBox>
                            
                            <TextBlock Text="提示词" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,8"/>
                            <TextBlock Text="支持 Markdown 格式" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryColor}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtProofreadPrompt" Style="{StaticResource TextBoxStyle}" 
                                     Margin="0,0,0,16" MinHeight="120" TextWrapping="Wrap" 
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            
                            <Button x:Name="BtnSaveProofreadConfig" Content="保存校验配置" 
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Proofread Status -->
                    <TextBlock x:Name="LblProofreadStatus" Text="状态: 就绪" 
                               Foreground="{StaticResource TextSecondaryColor}" FontSize="12" Margin="4,0,0,10"/>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Input Area -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#DDDDDD" 
                        BorderThickness="1" CornerRadius="20" Padding="12,8" Margin="0,0,8,0">
                    <TextBox x:Name="TxtInput" BorderThickness="0" Background="Transparent"
                             FontSize="13" VerticalAlignment="Center"
                             Text="输入消息..." Foreground="{StaticResource TextSecondaryColor}"/>
                </Border>
                <Button x:Name="BtnSend" Grid.Column="1" Width="36" Height="36"
                        Background="{StaticResource PrimaryColor}" BorderThickness="0">
                    <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>
        
        <!-- Bottom Navigation -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="0,1,0,0" Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="BtnNavChat" Grid.Column="0" Style="{StaticResource NavButtonStyle}"
                        Background="{StaticResource PrimaryLightColor}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Path Data="M21,15A2,2 0 0,1 19,17H7L3,21V5A2,2 0 0,1 5,3H19A2,2 0 0,1 21,5V15Z" 
                              Fill="{StaticResource PrimaryColor}" Width="20" Height="20" Stretch="Uniform"/>
                        <TextBlock Text="对话" FontSize="9" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="BtnNavSettings" Grid.Column="1" Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.4,15C19.5,15.3 19.7,15.6 19.9,15.8L21.2,17.1C21.5,17.4 21.5,17.9 21.2,18.2L19.9,19.5C19.6,19.8 19.1,19.8 18.8,19.5L17.5,18.2C17.3,18 17,17.8 16.7,17.7C16.1,17.9 15.5,18 15,18V20A1,1 0 0,1 14,21H12A1,1 0 0,1 11,20V18C10.5,18 9.9,17.9 9.3,17.7C9,17.8 8.7,18 8.5,18.2L7.2,19.5C6.9,19.8 6.4,19.8 6.1,19.5L4.8,18.2C4.5,17.9 4.5,17.4 4.8,17.1L6.1,15.8C6.3,15.6 6.5,15.3 6.6,15C6.2,14.4 6,13.7 6,13A4,4 0 0,1 6.6,11C6.5,10.7 6.3,10.4 6.1,10.2L4.8,8.9C4.5,8.6 4.5,8.1 4.8,7.8L6.1,6.5C6.4,6.2 6.9,6.2 7.2,6.5L8.5,7.8C8.7,8 9,8.2 9.3,8.3C9.9,8.1 10.5,8 11,8V6A1,1 0 0,1 12,5H14A1,1 0 0,1 15,6V8C15.5,8 16.1,8.1 16.7,8.3C17,8.2 17.3,8 17.5,7.8L18.8,6.5C19.1,6.2 19.6,6.2 19.9,6.5L21.2,7.8C21.5,8.1 21.5,8.6 21.2,8.9L19.9,10.2C19.7,10.4 19.5,10.7 19.4,11C19.8,11.6 20,12.3 20,13A4,4 0 0,1 19.4,15Z" 
                              Fill="{StaticResource TextSecondaryColor}" Width="20" Height="20" Stretch="Uniform"/>
                        <TextBlock Text="设置" FontSize="9" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
