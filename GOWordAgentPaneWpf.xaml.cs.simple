using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Text.RegularExpressions;
using System.Threading;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Shapes;
using Word = Microsoft.Office.Interop.Word;

namespace GOWordAgentAddIn
{
    public partial class GOWordAgentPaneWpf : UserControl
    {
        private ILLMService _llmService;
        private List<object> _messageHistory = new List<object>();
        private AIProvider _currentProvider = AIProvider.DeepSeek;

        private readonly SolidColorBrush _primaryColor = new SolidColorBrush(Color.FromRgb(0, 120, 212));
        private readonly SolidColorBrush _primaryLightColor = new SolidColorBrush(Color.FromRgb(232, 242, 252));
        private readonly SolidColorBrush _userBubbleColor = new SolidColorBrush(Color.FromRgb(227, 242, 253));
        private readonly SolidColorBrush _aiBubbleColor = new SolidColorBrush(Color.FromRgb(245, 245, 245));
        private readonly SolidColorBrush _textPrimaryColor = new SolidColorBrush(Color.FromRgb(34, 34, 34));
        private readonly SolidColorBrush _textSecondaryColor = new SolidColorBrush(Color.FromRgb(153, 153, 153));

        public GOWordAgentPaneWpf()
        {
            InitializeComponent();
            InitializeEvents();
            InitializeAIProviderComboBox();
            LoadSavedConfig();
            
            // 设置顶部标题栏为就绪状态
            UpdateHeaderStatus("就绪", Brushes.Green);
            
            // 显示初始化消息
            string proofreadMode = ConfigManager.CurrentConfig.ProofreadMode ?? "精准校验";
            try
            {
                AddMessageBubble("系统", $"当前校验模式 {proofreadMode}", false);
            }
            catch { }
            
            // 检查是否自动连接
            if (ConfigManager.CurrentConfig.AutoConnect)
            {
                _ = AutoConnectAsync();
            }
            else
            {
                UpdateAIConfigStatus("未连接", _textSecondaryColor);
                try
                {
                    AddMessageBubble("系统", "当前未连接AI大模型", false);
                }
                catch { }
            }
        }

        private async Task AutoConnectAsync()
        {
            try
            {
                var config = ConfigManager.CurrentConfig;
                var providerConfig = ConfigManager.GetProviderConfig(config.Provider);
                
                if (providerConfig == null || string.IsNullOrWhiteSpace(providerConfig.ApiKey))
                {
                    UpdateAIConfigStatus("未找到保存的 API Key", _textSecondaryColor);
                    return;
                }

                UpdateAIConfigStatus("正在连接...", _primaryColor);
                
                _llmService = LLMServiceFactory.CreateService(
                    config.Provider, 
                    providerConfig.ApiKey, 
                    providerConfig.ApiUrl, 
                    providerConfig.Model);

                UpdateAIConfigStatus($"已连接", Brushes.Green);
                AddMessageBubble("系统", $"当前连接的AI大模型 {_llmService.ProviderName}", false);
            }
            catch (Exception ex)
            {
                UpdateAIConfigStatus($"连接失败", Brushes.Red);
                try
                {
                    AddMessageBubble("系统", "当前未连接AI大模型", false);
                }
                catch { }
            }
        }

        private void AddMessageBubble(string sender, string message, bool isUser, bool isError = false)
        {
            if (ChatMessagesPanel == null) return;

            var bubbleBorder = new Border
            {
                Background = isError ? new SolidColorBrush(Color.FromRgb(255, 235, 238)) : (isUser ? _userBubbleColor : _aiBubbleColor),
                CornerRadius = new CornerRadius(12, 12, isUser ? 4 : 12, isUser ? 12 : 4),
                Padding = new Thickness(12, 10, 12, 10),
                MaxWidth = 280,
                Margin = new Thickness(0, 0, 0, 4)
            };

            var stackPanel = new StackPanel();
            
            var headerText = new TextBlock
            {
                Text = $"{sender} {DateTime.Now:HH:mm}",
                FontSize = 10,
                Foreground = _textSecondaryColor,
                Margin = new Thickness(0, 0, 0, 4)
            };
            stackPanel.Children.Add(headerText);

            stackPanel.Children.Add(new TextBlock
            {
                Text = message,
                FontSize = 13,
                Foreground = isError ? Brushes.Red : _textPrimaryColor,
                TextWrapping = TextWrapping.Wrap
            });

            bubbleBorder.Child = stackPanel;

            var container = new Grid
            {
                HorizontalAlignment = isUser ? HorizontalAlignment.Right : HorizontalAlignment.Left,
                Margin = new Thickness(0, 0, 0, 8)
            };
            container.Children.Add(bubbleBorder);

            ChatMessagesPanel.Children.Add(container);
            ChatScrollViewer.ScrollToEnd();
        }

        private void UpdateHeaderStatus(string text, Brush color)
        {
            if (LblHeaderStatus != null)
            {
                LblHeaderStatus.Text = $"状态：{text}";
                LblHeaderStatus.Foreground = color;
            }
        }

        private void UpdateAIConfigStatus(string text, Brush color)
        {
            if (LblAIConfigStatus != null)
            {
                LblAIConfigStatus.Text = $"状态：{text}";
                LblAIConfigStatus.Foreground = color;
            }
        }
    }
}
